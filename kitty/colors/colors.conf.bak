## name: Midnight Electric
## author: user
## blurb: Dark blue theme with yellow highlights

# The basic colors
foreground            #ece9ff
background            #0b0914
selection_foreground  #ece9ff
selection_background  #31295a

# Cursor colors
cursor                #ffd75e
cursor_text_color     #0b0914

# URL underline color when hovering with mouse
url_color             #4fdfff

# Kitty window border colors
active_border_color   #0038ff
inactive_border_color #31295a
bell_border_color     #ffd75e

# OS Window titlebar colors
wayland_titlebar_color system
macos_titlebar_color   system

# Tab bar colors
active_tab_foreground   #0b0914
active_tab_background   #ffd75e

inactive_tab_foreground #c9c6e4
inactive_tab_background #31295a

tab_bar_background      #0b0914


# Colors for marks (marked text in the terminal)

mark1_foreground #0b0914
mark1_background #0038ff

mark2_foreground #0b0914
mark2_background #ffd75e

mark3_foreground #0b0914
mark3_background #4fdfff


# The 16 terminal colors

# black
color0  #0b0914
color8  #7f7a9b


# red
color1  #ff5f87
color9  #ff85a6


# green
color2  #56e39f
color10 #74ebb0


# yellow
color3  #ffd75e
color11 #ffe48a


# blue
color4  #0038ff
color12 #2f66ff


# magenta
color5  #6800ff
color13 #8d4cff


# cyan
color6  #4fdfff
color14 #7be8ff


# white
color7  #ece9ff
color15 #ffffff
